# Production Environment Template
# Copy to .env for local production runs, or add in your host's environment settings.

# ── Application ──────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Justapedia API ───────────────────────────────────────────────────────────
# Usually leave these at defaults unless you run a staging wiki.
# JUSTAPEDIA_API_URL=https://justapedia.org/api.php
# JUSTAPEDIA_WIKI_ORIGIN=https://justapedia.org
# JPTOOLS_USER_AGENT=JPTools/1.0 (tools.justapedia.org; contact: you@example.com)
