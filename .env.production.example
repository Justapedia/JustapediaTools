# Production Environment Template
# Rename this file to .env on your VPS

# Option A: Using Tor (if installed via setup-vps.sh)
# SOCKS_PROXY=socks5://127.0.0.1:9050

# Option B: Using a Paid/Private Proxy (Recommended for stability)
# Replace with your actual proxy details
SOCKS_PROXY=socks5://username:password@proxy-host:port

# Application Port
PORT=3000

# Environment
NODE_ENV=production
